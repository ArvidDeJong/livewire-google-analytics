{
  "name": "darvis/livewire-google-analytics",
  "description": "Clean Google Analytics 4 event tracking for Laravel Livewire applications",
  "keywords": [
    "laravel",
    "livewire",
    "google-analytics",
    "ga4",
    "analytics",
    "tracking",
    "events"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Arvid de Jong",
      "email": "info@arvid.nl"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "livewire/livewire": "^3.0|^4.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "pestphp/pest": "^2.0|^3.0|^4.0",
    "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0"
  },
  "autoload": {
    "psr-4": {
      "Darvis\\LivewireGoogleAnalytics\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Darvis\\LivewireGoogleAnalytics\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "test-coverage": "vendor/bin/pest --coverage"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Darvis\\LivewireGoogleAnalytics\\GoogleAnalyticsServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
